#!/usr/bin/env python3
"""Render an elegant Turing-machine-inspired heart animation.

The animation shows a tiny symbolic machine following local rules while its
read/write head traces a continuous, grid-adjacent heart shape.  The heart is
constructed programmatically from the classic parametric heart curve and then
rasterized into adjacent grid steps; no coordinates are hand-authored.

Usage:
    python turing_hilbert_animation.py --self-test
    python turing_hilbert_animation.py --output a_turing_machine.mp4
    python turing_hilbert_animation.py --output a_turing_machine.gif

By default the film is a seamless loop: it emerges from a single red seed
cell, traces the outline, fills the heart, holds on it, then dives back into
one central red cell -- the finished heart becoming the seed of the next run.
"""

from __future__ import annotations

import argparse
import math
from pathlib import Path
from typing import Iterable, Literal, Sequence

Point = tuple[int, int]
Move = Literal["R", "L", "U", "D"]

SIZE = 64
VISUAL_SPACING = 1
VISUAL_SIZE = SIZE
HEART_SAMPLES = 900
scale = 2
# Pacing.  The film is a seamless loop of timed phases (seconds):
#   emerge from the red seed -> a few deliberately slow first steps ->
#   trace the rest of the outline -> fill the heart -> hold -> dive back to red.
# Everything here is tunable; passing --seconds rescales the phases together.
EMERGE_SECONDS = 1*scale         # pull out of the red seed to reveal the machine
STEP_HOLD_SECONDS = .5*scale        # each of the opening steps takes about this long
STEP_HOLD_COUNT = 2          # how many opening steps are deliberately slow
OUTLINE_SECONDS = 3*scale          # tracing the remainder of the outline
FILL_SECONDS = 3*scale            # filling the interior
HOLD_SECONDS = .75*scale            # resting on the completed heart
COLLAPSE_SECONDS = 2*scale        # diving into a central red cell, back to red
CAPTION_FADE_SECONDS = 2*scale     # how slowly captions crossfade (larger = slower)
DEFAULT_SECONDS = (
    EMERGE_SECONDS + STEP_HOLD_SECONDS * STEP_HOLD_COUNT + OUTLINE_SECONDS
    + FILL_SECONDS + HOLD_SECONDS + COLLAPSE_SECONDS
)

# Camera framing.  The single figure is centered in a 16:9 frame; its box aspect
# governs the data window so the heart fills the frame without letterbox or
# cropping.
AX_RECT = (0.14, 0.06, 0.72, 0.88)
BOX_ASPECT = (AX_RECT[2] * 16.0) / (AX_RECT[3] * 9.0)
SEED_HALF_Y = 0.55            # inside a single cell: a uniform red field
START_HALF_Y = 3.7            # zoomed in on the head at the start
FINAL_HALF_Y = 27.0          # frames the whole heart, centered, with margin

DARK = "#05070d"
GRID = "#d8dde8"
RED = "#ff0033"
WHITE = "#f4f7ff"
MUTED = "#8fa0b8"
AMBER = "#ffd166"
GOLD   = "#D3AE36"
SILVER = "#C1C1C1"

def connect_points(start: Point, end: Point) -> list[Point]:
    """Return a deterministic Manhattan path from start to end, excluding start."""

    x, y = start
    target_x, target_y = end
    path: list[Point] = []

    while x != target_x or y != target_y:
        dx = target_x - x
        dy = target_y - y
        if abs(dx) >= abs(dy) and dx != 0:
            x += 1 if dx > 0 else -1
        elif dy != 0:
            y += 1 if dy > 0 else -1
        path.append((x, y))

    return path


def quantized_heart_loop(size: int, samples: int, scale_factor: float, clockwise: bool) -> list[Point]:
    """Sample one scaled heart contour and quantize it into grid centers."""

    raw_points: list[tuple[float, float]] = []
    for index in range(samples):
        t = 2.0 * math.pi * index / samples
        x = 16.0 * math.sin(t) ** 3
        y = 13.0 * math.cos(t) - 5.0 * math.cos(2.0 * t) - 2.0 * math.cos(3.0 * t) - math.cos(4.0 * t)
        raw_points.append((x, y))

    min_x = min(x for x, _ in raw_points)
    max_x = max(x for x, _ in raw_points)
    min_y = min(y for _, y in raw_points)
    max_y = max(y for _, y in raw_points)
    margin = 5
    drawable = size - margin * 2 - 1
    scale = min(drawable / (max_x - min_x), drawable / (max_y - min_y)) * scale_factor
    center_x = (size - 1) / 2
    center_y = (size - 1) / 2
    raw_center_x = (min_x + max_x) / 2
    raw_center_y = (min_y + max_y) / 2

    quantized: list[Point] = []
    source_points = reversed(raw_points) if clockwise else raw_points
    for x, y in source_points:
        gx = round(center_x + (x - raw_center_x) * scale)
        gy = round(center_y + (y - raw_center_y) * scale)
        point = (int(gx), int(gy))
        if not quantized or quantized[-1] != point:
            quantized.append(point)

    return quantized



def point_in_polygon(point: tuple[float, float], polygon: Sequence[Point]) -> bool:
    """Return True when point lies inside polygon using ray casting."""

    x, y = point
    inside = False
    previous_x, previous_y = polygon[-1]
    for current_x, current_y in polygon:
        crosses = (current_y > y) != (previous_y > y)
        if crosses:
            slope_x = (previous_x - current_x) * (y - current_y) / (previous_y - current_y) + current_x
            if x < slope_x:
                inside = not inside
        previous_x, previous_y = current_x, current_y
    return inside


def heart_interior_cells(size: int = SIZE, samples: int = HEART_SAMPLES) -> set[Point]:
    """Return every grid cell whose center is inside the outer heart."""

    polygon = quantized_heart_loop(size, samples, scale_factor=1.0, clockwise=False)
    interior: set[Point] = set()
    for y in range(size):
        for x in range(size):
            if point_in_polygon((x, y), polygon):
                interior.add((x, y))
    return interior


def grid_neighbors(point: Point) -> tuple[Point, Point, Point, Point]:
    x, y = point
    return ((x + 1, y), (x - 1, y), (x, y + 1), (x, y - 1))


def shortest_path(start: Point, target: Point, allowed: set[Point]) -> list[Point]:
    """Return an adjacent path from start to target constrained to allowed cells."""

    if start == target:
        return []

    frontier = [start]
    came_from: dict[Point, Point | None] = {start: None}
    for current in frontier:
        for neighbor in grid_neighbors(current):
            if neighbor not in allowed or neighbor in came_from:
                continue
            came_from[neighbor] = current
            if neighbor == target:
                path = [target]
                while path[-1] != start:
                    parent = came_from[path[-1]]
                    if parent is None:
                        break
                    path.append(parent)
                path.reverse()
                return path[1:]
            frontier.append(neighbor)

    raise ValueError(f"No in-heart path from {start} to {target}")


def row_by_row_fill_path(start: Point, interior: set[Point], outline: Sequence[Point]) -> list[Point]:
    """Visit interior cells in horizontal rows after the outline is traced."""

    outline_cells = set(outline)
    allowed = set(interior) | outline_cells
    fill_cells = interior - outline_cells
    ordered_targets: list[Point] = []

    for row_index, y in enumerate(range(min(y for _, y in fill_cells), max(y for _, y in fill_cells) + 1)):
        row = sorted((cell for cell in fill_cells if cell[1] == y), key=lambda cell: cell[0])
        if row_index % 2 == 1:
            row.reverse()
        ordered_targets.extend(row)

    path: list[Point] = []
    current = start
    for target in ordered_targets:
        segment = shortest_path(current, target, allowed)
        path.extend(segment)
        current = target
    return path

def connected_loop(points: Sequence[Point]) -> list[Point]:
    """Connect a quantized contour into adjacent grid steps and close it."""

    if not points:
        return []

    loop: list[Point] = [points[0]]
    for point in list(points[1:]) + [points[0]]:
        loop.extend(connect_points(loop[-1], point))
    return loop


def start_loop_at_bottom(loop: Sequence[Point]) -> list[Point]:
    """Rotate a closed loop so its traversal begins at the heart tip."""

    if not loop:
        return []

    cells = list(loop)
    if len(cells) > 1 and cells[0] == cells[-1]:
        cells = cells[:-1]

    center_x = (min(x for x, _ in cells) + max(x for x, _ in cells)) / 2
    start_index = min(range(len(cells)), key=lambda index: (cells[index][1], abs(cells[index][0] - center_x)))
    rotated = cells[start_index:] + cells[:start_index]
    rotated.append(rotated[0])
    return rotated


def heart_paths(size: int = SIZE, samples: int = HEART_SAMPLES) -> tuple[list[Point], list[Point]]:
    """Return the bottom-starting outer heart trace and row-by-row fill."""

    if size < 16:
        raise ValueError("Heart grid size must be at least 16")
    if samples < 32:
        raise ValueError("Heart curve needs at least 32 samples")

    outline = start_loop_at_bottom(connected_loop(quantized_heart_loop(size, samples, scale_factor=1.0, clockwise=False)))
    interior = heart_interior_cells(size=size, samples=samples)
    fill = row_by_row_fill_path(outline[-1], interior, outline)

    return outline, fill


def heart_curve(size: int = SIZE, samples: int = HEART_SAMPLES) -> list[Point]:
    """Return a continuous traversal of an outlined, then filled, heart.

    The outer contour is traced first from the bottom tip of the classic
    parametric heart curve. Once the outline is complete, the path fills the
    heart one horizontal row at a time from bottom to top.
    """

    outline, fill = heart_paths(size=size, samples=samples)
    combined = outline + fill
    deduped: list[Point] = []
    for point in combined:
        if not deduped or deduped[-1] != point:
            deduped.append(point)
    return deduped

def move_between(a: Point, b: Point) -> Move:
    dx = b[0] - a[0]
    dy = b[1] - a[1]
    if (dx, dy) == (1, 0):
        return "R"
    if (dx, dy) == (-1, 0):
        return "L"
    if (dx, dy) == (0, 1):
        return "U"
    if (dx, dy) == (0, -1):
        return "D"
    raise ValueError(f"Non-adjacent points: {a} -> {b}")


def validate_curve(points: Sequence[Point], size: int = SIZE) -> None:
    """Raise ValueError unless points form a bounded adjacent traversal."""

    if len(points) < size:
        raise ValueError(f"Expected a substantial heart path, got only {len(points)} cells")
    for point in points:
        if not (0 <= point[0] < size and 0 <= point[1] < size):
            raise ValueError(f"Point outside {size} x {size} grid: {point}")
    for p, q in zip(points, points[1:]):
        if abs(p[0] - q[0]) + abs(p[1] - q[1]) != 1:
            raise ValueError(f"Disconnected segment: {p} -> {q}")


def validate_heart_fill(points: Sequence[Point], size: int = SIZE) -> None:
    """Raise ValueError if any interior heart cell is absent from the path."""

    missing = heart_interior_cells(size=size) - set(points)
    if missing:
        preview = sorted(missing)[:8]
        raise ValueError(f"Heart fill missed {len(missing)} interior cells, including {preview}")


def easing(t: float) -> float:
    """Smoothstep easing for gentle camera movement."""

    t = max(0.0, min(1.0, t))
    return t * t * (3.0 - 2.0 * t)


def smootherstep(t: float) -> float:
    """Ken Perlin's smootherstep: zero first and second derivatives at both ends."""

    t = max(0.0, min(1.0, t))
    return t * t * t * (t * (t * 6.0 - 15.0) + 10.0)


def outline_ease(t: float) -> float:
    """Mostly-linear trace with softened ends so the draw neither crawls nor snaps."""

    t = max(0.0, min(1.0, t))
    return 0.55 * t + 0.45 * smootherstep(t)


def fill_ease(t: float) -> float:
    """Gentle ease-out so the final rows settle instead of slamming shut."""

    t = max(0.0, min(1.0, t))
    return 1.0 - (1.0 - t) ** 1.5


def heartbeat(t: float, period: float = 1.0) -> float:
    """A double-thump (lub-dub) brightness envelope in [0, ~1] for the final hold."""

    phase = (t % period) / period

    def bump(center: float, width: float) -> float:
        return math.exp(-(((phase - center) / width) ** 2))

    return min(1.0, bump(0.12, 0.045) + 0.62 * bump(0.32, 0.052))


def interpolate(a: float, b: float, t: float) -> float:
    return a + (b - a) * t


def state_for_step(step: int) -> tuple[str, str, str]:
    states = ("q0", "q1", "q2", "q3")
    symbols = ("□", "♥")
    qi = states[step % len(states)]
    qj = states[(step + 1) % len(states)]
    write = symbols[(step + 1) % len(symbols)]
    return qi, qj, write


def visible_rule(step: int, move: Move) -> str:
    qi, qj, write = state_for_step(step)
    return f"({qi}, s) → ({qj}, {write}, {move})"


def rule_table_lines() -> list[str]:
    return [
        "(q0, □) → (q1, ♥, U)",
        "(q1, □) → (q2, ♥, R)",
        "(q2, □) → (q3, ♥, D)",
        "(q3, □) → (q0, ♥, L)",
        "heart boundary supplied by finite parametric sampler",
    ]


def render_animation(output: Path, fps: int = 30, seconds: float = DEFAULT_SECONDS) -> None:
    """Render the short film to an mp4 or gif file."""

    import matplotlib.animation as animation
    import matplotlib.pyplot as plt
    import numpy as np
    from matplotlib.patches import Arc, Circle, FancyBboxPatch, Polygon, Rectangle

    outline, _fill = heart_paths()
    points = heart_curve()
    validate_curve(points)
    validate_heart_fill(points)
    outline_end = min(len(outline) - 1, len(points) - 1)
    last_index = len(points) - 1

    total_frames = max(2, int(round(fps * seconds)))
    # Six timed phases (see module constants); --seconds rescales them together.
    scale = seconds / DEFAULT_SECONDS if DEFAULT_SECONDS > 0 else 1.0
    emerge_t = EMERGE_SECONDS * scale
    step_hold = STEP_HOLD_SECONDS * scale
    deliberate_t = step_hold * STEP_HOLD_COUNT
    outline_trace_t = OUTLINE_SECONDS * scale
    fill_t = FILL_SECONDS * scale
    hold_t = HOLD_SECONDS * scale
    collapse_t = COLLAPSE_SECONDS * scale
    caption_fade = CAPTION_FADE_SECONDS * scale
    outline_t = deliberate_t + outline_trace_t

    t_emerge_end = emerge_t
    t_deliberate_end = t_emerge_end + deliberate_t
    t_out_end = t_deliberate_end + outline_trace_t
    t_fill_end = t_out_end + fill_t
    t_hold_end = t_fill_end + hold_t
    t_collapse_end = t_hold_end + collapse_t

    center = (VISUAL_SIZE - 1) / 2.0
    point_x = np.array([x * VISUAL_SPACING for x, _ in points], dtype=int)
    point_y = np.array([y * VISUAL_SPACING for _, y in points], dtype=int)
    seed_x, seed_y = float(point_x[0]), float(point_y[0])
    glow_rgba = np.zeros((VISUAL_SIZE, VISUAL_SIZE, 4), dtype=float)
    cell_rgba = np.zeros((VISUAL_SIZE, VISUAL_SIZE, 4), dtype=float)
    red_rgb = tuple(int(RED[i : i + 2], 16) / 255 for i in (1, 3, 5))
    glow_rgba[:, :, :3] = red_rgb
    cell_rgba[:, :, :3] = red_rgb

    fig = plt.figure(figsize=(16, 9), facecolor=DARK)
    ax = fig.add_axes(list(AX_RECT), facecolor=DARK)

    ax.set_aspect("equal")
    grid_lines = [i - 0.5 for i in range(VISUAL_SIZE + 1)]
    ax.set_xticks(grid_lines)
    ax.set_yticks(grid_lines)
    ax.grid(color=GRID, alpha=0.30, linewidth=0.48)
    ax.tick_params(left=False, bottom=False, labelleft=False, labelbottom=False)
    for spine in ax.spines.values():
        spine.set_visible(False)

    glow_cells = ax.imshow(
        glow_rgba,
        extent=(-0.5, VISUAL_SIZE - 0.5, -0.5, VISUAL_SIZE - 0.5),
        origin="lower",
        interpolation="bilinear",
        zorder=1,
    )
    lit_cells = ax.imshow(
        cell_rgba,
        extent=(-0.5, VISUAL_SIZE - 0.5, -0.5, VISUAL_SIZE - 0.5),
        origin="lower",
        interpolation="nearest",
        zorder=2,
    )

    # --- Read/write head -------------------------------------------------
    # A small carriage that rides above the current cell: a rounded housing
    # carrying the machine state, a neck, and a glowing nib pointing down into
    # the cell it is writing.  It reads as a machine leaving red behind it.
    HOUSE_DY, HOUSE_W, HOUSE_H = 1.20, 1.9, 1.0
    hx0, hy0 = float(point_x[0]), float(point_y[0])

    halo = Circle((hx0, hy0 + HOUSE_DY - 0.05), radius=1.7, facecolor=RED, edgecolor="none", alpha=0.16, zorder=5)
    nib_glow = Polygon(
        [[hx0, hy0 - 0.2], [hx0 - 0.62, hy0 + 0.5], [hx0 + 0.62, hy0 + 0.5]],
        closed=True, facecolor=RED, edgecolor="none", alpha=0.32, zorder=6,
    )
    neck = Rectangle((hx0 - 0.1, hy0 + 0.34), 0.2, 0.40, facecolor="#0e1626", edgecolor="#e8ecf6", linewidth=0.8, zorder=7)
    housing = FancyBboxPatch(
        (hx0 - HOUSE_W / 2, hy0 + HOUSE_DY - HOUSE_H / 2), HOUSE_W, HOUSE_H,
        boxstyle="round,pad=0,rounding_size=0.26",
        facecolor="#0e1626", edgecolor="#e8ecf6", linewidth=1.15, zorder=8,
    )
    nib = Polygon(
        [[hx0, hy0], [hx0 - 0.34, hy0 + 0.38], [hx0 + 0.34, hy0 + 0.38]],
        closed=True, facecolor=RED, edgecolor="#ff8ba3", linewidth=0.9, zorder=9,
    )
    lamp_a = Circle((hx0 - 0.58, hy0 + HOUSE_DY + 0.26), radius=0.11, facecolor=AMBER, edgecolor="none", zorder=10)
    lamp_b = Circle((hx0 + 0.58, hy0 + HOUSE_DY + 0.26), radius=0.11, facecolor=WHITE, edgecolor="none", zorder=10)
    for patch in (halo, nib_glow, neck, housing, nib, lamp_a, lamp_b):
        ax.add_patch(patch)
    smile = Arc(
        (hx0, hy0 + HOUSE_DY - 0.06), 0.55, 0.28, angle=0.0, theta1=215, theta2=325,
        edgecolor="#dfe6f2", linewidth=1.25, zorder=11,
    )
    ax.add_patch(smile)

    head_parts = [
        (halo, 0.16), (nib_glow, 0.32), (neck, 1.0), (housing, 1.0),
        (nib, 1.0), (lamp_a, 1.0), (lamp_b, 1.0), (smile, 0.9),
    ]

    def place_head(hx: float, hy: float) -> None:
        halo.center = (hx, hy + HOUSE_DY - 0.05)
        nib_glow.set_xy([[hx, hy - 0.2], [hx - 0.62, hy + 0.5], [hx + 0.62, hy + 0.5], [hx, hy - 0.2]])
        neck.set_xy((hx - 0.1, hy + 0.34))
        housing.set_bounds(hx - HOUSE_W / 2, hy + HOUSE_DY - HOUSE_H / 2, HOUSE_W, HOUSE_H)
        nib.set_xy([[hx, hy], [hx - 0.34, hy + 0.38], [hx + 0.34, hy + 0.38], [hx, hy]])
        lamp_a.center = (hx - 0.58, hy + HOUSE_DY + 0.26)
        lamp_b.center = (hx + 0.58, hy + HOUSE_DY + 0.26)
        smile.set_center((hx, hy + HOUSE_DY - 0.06))

    def fade_head(alpha: float) -> None:
        a = max(0.0, min(1.0, alpha))
        for artist, base in head_parts:
            artist.set_alpha(base * a)

    title = fig.text(0.5, 0.94, "eyes of the beholder", color=WHITE, fontsize=28, fontweight="light", ha="center", family="DejaVu Sans")
    caption1 = fig.text(
        0.5, 0.45, "", color=SILVER, fontsize=26, ha="center", va="center", family="DejaVu Sans"
    )
    caption2 = fig.text(
        0.5, 0.05, "", color=GOLD, fontsize=23, ha="center", va="center", family="DejaVu Sans"
    )

    # A full-figure red layer.  It is opaque only at the very first and very
    # last frames, so the film begins and ends on the same uniform red field --
    # the seam of the loop, where the heart's centre and the next seed are one.
    red_seam = Rectangle((0, 0), 1, 1, transform=fig.transFigure,
                         facecolor=RED, edgecolor="none", zorder=60, alpha=0.0)
    fig.add_artist(red_seam)

    def frame_to_step(frame: int) -> float:
        t = frame / fps
        if t <= t_emerge_end:                     # resting at the seed
            return 0.0
        if t <= t_deliberate_end:                 # first steps, one slow cell at a time
            u = (t - t_emerge_end) / deliberate_t if deliberate_t > 0 else 1.0
            return u * STEP_HOLD_COUNT
        if t <= t_out_end:                        # trace the rest of the outline
            u = outline_ease((t - t_deliberate_end) / outline_trace_t if outline_trace_t > 0 else 1.0)
            return STEP_HOLD_COUNT + u * (outline_end - STEP_HOLD_COUNT)
        if t <= t_fill_end:                       # fill the interior
            u = fill_ease((t - t_out_end) / fill_t if fill_t > 0 else 1.0)
            return outline_end + u * (last_index - outline_end)
        return float(last_index)                  # hold + collapse

    def camera(frame: int, hx: float, hy: float) -> tuple[float, float, float, float]:
        """Emerge from the seed, linger on the slow first steps, pull back, lock, dive."""

        t = frame / fps
        if t <= t_emerge_end:                     # zoom out of the red seed cell
            z = smootherstep(t / emerge_t if emerge_t > 0 else 1.0)
            half_y = interpolate(SEED_HALF_Y, START_HALF_Y, z)
            cx, cy = seed_x, seed_y
        elif t <= t_deliberate_end:               # linger close on the slow first steps
            half_y = START_HALF_Y
            cx, cy = hx, hy
        elif t <= t_out_end:                      # pull back to frame the whole heart
            z = smootherstep((t - t_deliberate_end) / outline_trace_t if outline_trace_t > 0 else 1.0)
            half_y = interpolate(START_HALF_Y, FINAL_HALF_Y, z)
            cx = interpolate(hx, center, z)
            cy = interpolate(hy, center, z)
        elif t <= t_hold_end:                     # locked, centered, static
            half_y = FINAL_HALF_Y
            cx = cy = center
        else:                                     # dive into one central red cell
            z = smootherstep((t - t_hold_end) / collapse_t if collapse_t > 0 else 1.0)
            half_y = interpolate(FINAL_HALF_Y, SEED_HALF_Y, z)
            cx = cy = center
        return cx, cy, half_y * BOX_ASPECT, half_y

    def ramp(t: float, a: float, b: float) -> float:
        if b <= a:
            return 1.0 if t >= b else 0.0
        return max(0.0, min(1.0, (t - a) / (b - a)))

    def update(frame: int) -> Iterable[object]:
        t = frame / fps
        step_float = frame_to_step(frame)
        step = min(int(step_float), last_index - 1)
        frac = step_float - step
        p = points[step]
        q = points[step + 1]
        hx = interpolate(point_x[step], point_x[step + 1], frac)
        hy = interpolate(point_y[step], point_y[step + 1], frac)
        move = move_between(p, q)

        fill_step = min(int(step_float), last_index)
        visited_x = point_x[: fill_step + 1]
        visited_y = point_y[: fill_step + 1]

        # Brightness: a barely-there breath while building, then a real cardiac
        # lub-dub once the heart is whole and the frame goes still.
        if t < t_fill_end:
            breathe = 0.90 + 0.05 * math.sin(2.0 * math.pi * t / 2.6)
            glow_mult, core_mult = breathe, breathe
        else:
            beat = heartbeat(t - t_fill_end, period=2.0)
            glow_mult = 0.90 + 0.45 * beat
            core_mult = 0.88 + 0.24 * beat

        glow_rgba[:, :, 3] = 0.0
        cell_rgba[:, :, 3] = 0.0
        glow_rgba[visited_y, visited_x, 3] = min(1.0, 0.90 * glow_mult)
        cell_rgba[visited_y, visited_x, 3] = min(1.0, 0.54 * core_mult)
        glow_cells.set_data(glow_rgba)
        lit_cells.set_data(cell_rgba)

        # The machine surfaces from the seed, writes, then dissolves into what
        # it made.
        place_head(hx, hy)
        head_in = ramp(t, emerge_t * 0.45, emerge_t * 0.95)
        head_out = 1.0 - ramp(t, t_fill_end - 0.7, t_fill_end)
        head_alpha = min(head_in, head_out)
        

        qi, qj, write = state_for_step(step)
        

        cx, cy, half_x, half_y = camera(frame, hx, hy)
        ax.set_xlim(cx - half_x, cx + half_x)
        ax.set_ylim(cy - half_y, cy + half_y)

        # Title carries the reveal: in as the red clears, out as the fill begins.
        title.set_alpha(min(ramp(t, t_emerge_end, t_emerge_end + 0.4),
                            1.0 - ramp(t, t_out_end - outline_t * 0.3, t_out_end + fill_t * 0.12)))

        # Live machine readout during outline + fill; clears for the final hold.
        machine_alpha = 1.0 - ramp(t, t_fill_end, t_fill_end + 0.4)
        # Rule table fades in over the fill and holds, then clears for the dive.
        table_alpha = min(ramp(t, t_out_end + 0.2, t_out_end + 0.9),
                          1.0 - ramp(t, t_hold_end, t_hold_end + collapse_t * 0.5))
        # Caption timing follows the story beats: the first appears only after
        # the deliberately slow opening steps finish, then it slowly crossfades
        # into the second just before the fill begins after the outline trace.
        bridge_start = max(t_deliberate_end, t_out_end - caption_fade)
        caption1_alpha = min(
            ramp(t, t_deliberate_end, t_deliberate_end + caption_fade),
            1.0 - ramp(t, bridge_start, t_out_end),
        )
        caption2_alpha = min(
            ramp(t, bridge_start+3.5, t_out_end+3.5),
            1.0 - ramp(t, t_hold_end+3.5, t_hold_end+3.5+ collapse_t * 0.5),
        )
        caption1.set_text("Love is found in the simple act of being.")
        caption2.set_text("Beauty, in simplicity becoming.")
        caption1.set_alpha(caption1_alpha)
        caption2.set_alpha(caption2_alpha)

        # The loop seam: opaque red at the first and last frames only, so the
        # end (diving into the heart's core) and the start (the lone red seed)
        # are one uniform field.  The output becomes the next initialization.
        seam_alpha = max(1.0 - ramp(t, 0.0, emerge_t * 0.6),
                         ramp(t, t_hold_end + collapse_t * 0.4, t_hold_end + collapse_t * 0.9))
        red_seam.set_alpha(seam_alpha)

        return (glow_cells, lit_cells, halo, nib_glow, neck, housing, nib,
                lamp_a, lamp_b,
                caption1, caption2, red_seam)

    anim = animation.FuncAnimation(fig, update, frames=total_frames, interval=1000 / fps, blit=False)
    output.parent.mkdir(parents=True, exist_ok=True)
    suffix = output.suffix.lower()
    if suffix == ".gif":
        anim.save(output, writer=animation.PillowWriter(fps=fps))
    else:
        anim.save(output, writer=animation.FFMpegWriter(fps=fps, bitrate=2600))
    plt.close(fig)


def main() -> None:
    parser = argparse.ArgumentParser(description="Render 'A Turing Machine', a heart-tracing animation.")
    parser.add_argument("--output", type=Path, default=Path("a_turing_machine2.mp4"), help="Output .mp4 or .gif path")
    parser.add_argument("--fps", type=int, default=20, help="Frames per second")
    parser.add_argument("--seconds", type=float, default=DEFAULT_SECONDS, help="Animation duration")
    parser.add_argument("--self-test", action="store_true", help="Validate the heart traversal and exit")
    args = parser.parse_args()

    points = heart_curve()
    validate_curve(points)
    validate_heart_fill(points)
    if args.self_test:
        print(f"OK: heart traversal visits {len(points)} adjacent grid cells on a {SIZE}x{SIZE} grid")
        return
    render_animation(args.output, fps=args.fps, seconds=args.seconds)
    print(f"Rendered {args.output}")


if __name__ == "__main__":
    main()
